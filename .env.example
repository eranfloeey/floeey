# Admin auth
ADMIN_PASSWORD=change-me
ADMIN_SECRET=change-me-to-a-long-random-string

# Postgres (Vercel auto-injects POSTGRES_URL when you attach a Postgres database)
# POSTGRES_URL=

# NLPearl outbound — fires on every lead. Set both to enable.
# Outbound URL is the per-account Lead endpoint, including the outboundId path segment.
NLPEARL_OUTBOUND_URL=https://api.nlpearl.ai/v2/Outbound/<outboundId>/Lead
# Full Authorization header value, including the "Bearer " prefix.
NLPEARL_AUTH=Bearer <accountId>:<accountSecret>
